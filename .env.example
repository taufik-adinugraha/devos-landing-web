# Sentry DSN for server-side error tracking (SSR, API routes)
# Find this in: Sentry project settings → Client Keys (DSN)
SENTRY_DSN=

# Sentry DSN for client-side error tracking (browser bundle)
# Usually the same value as SENTRY_DSN
# This var is baked into the browser bundle at BUILD TIME
# If deploying via Docker, pass as --build-arg NEXT_PUBLIC_SENTRY_DSN=...
NEXT_PUBLIC_SENTRY_DSN=

# Sentry auth token for uploading source maps (optional, CI/CD only)
# Generate in: Sentry settings → Auth Tokens
# SENTRY_AUTH_TOKEN=

# Webhook URL for wait-list sign-ups (optional)
# Example: Zapier webhook, Mailchimp API endpoint, custom backend
# WAITLIST_WEBHOOK_URL=

# Environment (development | production | test)
NODE_ENV=development
